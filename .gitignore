# env files (contain optional API keys)
.env
.env.*
!.env.example

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build artifacts (regenerated by CI)
node_modules
dist
dist-ssr
*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite cache
.vite

# IMPORTANT: do NOT ignore public/snapshot.json — it must be committed
# so the deployed GitHub Pages site has it (even on first deploy before
# the daily workflow runs).
!public/snapshot.json
