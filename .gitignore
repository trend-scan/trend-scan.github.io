# env files (contain optional API keys)
.env
.env.*
!.env.example

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build artifacts (regenerated by CI)
node_modules
dist
dist-ssr
*.local

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite cache
.vite

# IMPORTANT: do NOT ignore public/snapshot.json — it must be committed
# so the deployed GitHub Pages site has it (even on first deploy before
# the daily workflow runs).
!public/snapshot.json

# IMPORTANT: DO ignore public/snapshot.tradfi.json on main branch.
# This 13MB file is committed 3× daily by refresh-snapshot.yml, which would
# bloat main's history by ~39MB/day. Instead, it's pushed directly to the
# gh-pages branch (deployed branch) where history is ephemeral.
# The deploy workflow still copies it from public/ into dist/ if present.
public/snapshot.tradfi.json

# Ortho backtest data cache (13 symbols × 43 months of Binance daily klines
# with taker_buy_vol — only used by scripts/signal/ortho_daily_backtest.py)
data/historical/_ortho_cache/
