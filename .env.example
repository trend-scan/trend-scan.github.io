# === Client-side env vars (safe to expose, baked into bundle) ===
# Copy this file to .env and fill in values. .env is gitignored.

# Massive/Polygon API key — OPTIONAL. The multi-source resolver now handles
# crypto OHLC via CoinGecko, Binance, OKX, Kraken, Hyperliquid, Bybit, Gate, Kucoin.
# Only set this if you have a paid Polygon plan and want to use it as a source.
VITE_MASSIVE_API_KEY=

# Alpha Vantage free key — OPTIONAL. 'demo' works for CPI; register for full access.
# https://www.alphavantage.co/support/#api-key
VITE_ALPHAVANTAGE_KEY=demo

# === Server-side only secrets (set in GitHub repo Settings → Secrets, NOT here) ===
# FRED_API_KEY — used by the daily-snapshot GitHub Action to fetch macro data server-side
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
