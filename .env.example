# === Client-side env vars (safe to expose, baked into bundle) ===
# Copy this file to .env and fill in values. .env is gitignored.
#
# Only NON-SECRET values go here. VITE_-prefixed vars get statically inlined
# into the client JS bundle by Vite, so anything here is visible to anyone
# who inspects the bundle. Do NOT put API keys here.

# Cloudflare Worker URL for Yahoo Finance proxy (just a URL, not a secret).
# If unset, falls back to the hardcoded worker URL in traditionalMarkets.js.
# VITE_YAHOO_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# Feature flag for FactorWatch integration (boolean string 'true'/'false').
# VITE_ENABLE_FACTORWATCH=true

# === Server-side only secrets (set in GitHub repo Settings → Secrets, NOT here) ===
# FRED_API_KEY — used by the daily-snapshot GitHub Action to fetch macro data
# server-side. Never exposed to the client.
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html

# === Runtime API keys (set via browser localStorage, NOT env vars) ===
# Paid API keys for optional data sources. These are NOT baked into the bundle.
# Users who want these sources set them at runtime in the browser console:
#
#   localStorage.setItem('MASSIVE_API_KEY', 'your_polygon_key')     # Polygon.io
#   localStorage.setItem('TWELVEDATA_KEY', 'your_twelvedata_key')   # Twelve Data
#   localStorage.setItem('ALPHAVANTAGE_KEY', 'your_av_key')         # Alpha Vantage
#
# Without these keys, the app uses free sources (OKX, Kraken, Bybit, Yahoo,
# CoinGecko, Hyperliquid) which cover 300+ assets with no key required.
